# Berth configuration — copy to .env.local and edit. All vars are optional.

# Where to bind the dev/prod server (loopback by default — keep it on 127.0.0.1
# unless you're fronting it with `tailscale serve` or a reverse proxy you trust).
# BERTH_CONTROL_PORT=5202
# BERTH_CONTROL_HOST=127.0.0.1

# SQLite location. Defaults to ~/.berth-control/berth.db.
# BERTH_CONTROL_DB=/home/you/.berth-control/berth-control.db

# Markdown registry. Defaults to ~/PORTS.md. If neither exists, Berth starts
# with an empty registry and you add apps from the UI.
# BERTH_CONTROL_PORTS_MD=/home/you/PORTS.md

# Extra hostnames for Vite's `allowedHosts` (dev only). Comma-separated.
# Use a leading dot to match any subdomain. Loopback (localhost / 127.0.0.1)
# and `.ts.net` (any Tailscale tailnet) are always allowed by default —
# only add LAN hostnames, custom domains, or reverse-proxy fronts here.
# Example: BERTH_CONTROL_ALLOWED_HOSTS=berth.lan,.example.com
# BERTH_CONTROL_ALLOWED_HOSTS=

# ── Host monitor (/monitor page) ─────────────────────────────────────────
# All optional; sensible defaults inside the code.

# Normal sample cadence in seconds. The collector adapts to FAST_INTERVAL_SECS
# when memory pressure exceeds RAM_PRESSURE_PCT.
# BERTH_CONTROL_MONITOR_INTERVAL_SECS=60
# BERTH_CONTROL_MONITOR_FAST_INTERVAL_SECS=10
# BERTH_CONTROL_MONITOR_RAM_PRESSURE_PCT=80

# How long to keep host_readings rows before the retention sweep drops them.
# BERTH_CONTROL_MONITOR_RETENTION_DAYS=90

# Web Push contact — required to enable push notifications. The VAPID spec
# uses this as a way for push providers to reach the server operator. Must
# be a mailto: or https:// URL you control. Example:
#   BERTH_CONTROL_MONITOR_PUSH_CONTACT=mailto:admin@example.com
# Leave unset to disable push (alerts still appear in the in-page log).
# BERTH_CONTROL_MONITOR_PUSH_CONTACT=
