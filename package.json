{
  "name": "berth",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Local-only control panel for every dev server on your machine. Tailscale-gated.",
  "keywords": [
    "developer-tools",
    "dashboard",
    "process-manager",
    "sveltekit",
    "svelte",
    "tailscale",
    "bun",
    "local-development",
    "dev-server"
  ],
  "homepage": "https://github.com/nguyentuansi/berth#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nguyentuansi/berth.git"
  },
  "bugs": "https://github.com/nguyentuansi/berth/issues",
  "license": "MIT",
  "author": "nguyentuansi",
  "scripts": {
    "dev": "vite dev --port 5202 --host 127.0.0.1",
    "build": "vite build",
    "preview": "node build/index.js",
    "start": "PORT=5202 HOST=127.0.0.1 node build/index.js",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "demo:seed": "BERTH_DB=./demo.db bun run scripts/seed-demo.ts",
    "demo:dev": "BERTH_DEMO=1 BERTH_DB=./demo.db bunx vite dev --port 5203 --host 127.0.0.1",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json"
  },
  "dependencies": {
    "@fontsource/inter": "^5.1.0",
    "@fontsource/jetbrains-mono": "^5.1.0",
    "better-sqlite3": "^11.5.0",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.36.4",
    "lucide-svelte": "^0.469.0",
    "mode-watcher": "^0.5.0",
    "tailwind-merge": "^2.5.2"
  },
  "devDependencies": {
    "@sveltejs/adapter-node": "^5.2.9",
    "@sveltejs/kit": "^2.15.0",
    "@sveltejs/vite-plugin-svelte": "^5.0.0",
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.0.0",
    "autoprefixer": "^10.4.20",
    "drizzle-kit": "^0.28.1",
    "postcss": "^8.4.49",
    "svelte": "^5.20.0",
    "svelte-check": "^4.1.0",
    "tailwindcss": "^3.4.17",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "^5.6.0",
    "vite": "^6.0.0"
  }
}
