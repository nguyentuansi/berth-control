{
  "name": "berth-control",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Local-only control panel for every dev server on your machine. Tailscale-gated.",
  "keywords": [
    "developer-tools",
    "dashboard",
    "process-manager",
    "sveltekit",
    "svelte",
    "tailscale",
    "bun",
    "local-development",
    "dev-server"
  ],
  "homepage": "https://github.com/nguyentuansi/berth-control#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nguyentuansi/berth-control.git"
  },
  "bugs": "https://github.com/nguyentuansi/berth-control/issues",
  "license": "MIT",
  "author": "nguyentuansi",
  "scripts": {
    "dev": "vite dev --port 5202 --host 127.0.0.1",
    "build": "vite build",
    "preview": "node build/index.js",
    "start": "PORT=5202 HOST=127.0.0.1 node build/index.js",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "demo:seed": "BERTH_CONTROL_DB=./demo.db bun run scripts/seed-demo.ts",
    "demo:dev": "BERTH_CONTROL_DEMO=1 BERTH_CONTROL_DB=./demo.db bunx vite dev --port 5203 --host 127.0.0.1",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "build:native": "cd native && node-gyp rebuild",
    "postinstall": "node scripts/build-native.mjs"
  },
  "dependencies": {
    "@berth/ui": "file:../berth/packages/ui",
    "@fontsource/fraunces": "^5.2.9",
    "@fontsource/ibm-plex-mono": "^5.2.7",
    "@fontsource/ibm-plex-sans": "^5.2.8",
    "@fontsource/inter": "^5.1.0",
    "@fontsource/jetbrains-mono": "^5.1.0",
    "better-sqlite3": "^11.5.0",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.36.4",
    "lucide-svelte": "^0.469.0",
    "mode-watcher": "^0.5.0",
    "qrcode": "^1.5.4",
    "tailwind-merge": "^2.5.2",
    "web-push": "^3.6.7"
  },
  "devDependencies": {
    "@sveltejs/adapter-node": "^5.2.9",
    "@sveltejs/kit": "^2.15.0",
    "@sveltejs/vite-plugin-svelte": "^5.0.0",
    "@tailwindcss/vite": "^4.2.2",
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.0.0",
    "@types/qrcode": "^1.5.5",
    "drizzle-kit": "^0.28.1",
    "node-gyp": "^10.2.0",
    "playwright": "^1.61.1",
    "svelte": "^5.20.0",
    "svelte-check": "^4.1.0",
    "tailwindcss": "^4.2.2",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.6.0",
    "vite": "^6.0.0"
  }
}
